{
  "manifest_version": 3,
  "name": "ZenTube",
  "version": "1.0",
  "description": "A distraction-free YouTube experience.",

  "permissions": ["storage", "tabs"],

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "action": {
    "default_popup": "popup.html",

    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
